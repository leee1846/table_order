{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./src/auth/index.ts"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/types/index.ts"
    },
    "./cores": {
      "types": "./dist/cores/index.d.ts",
      "default": "./src/cores/index.ts"
    },
    "./queries": {
      "types": "./dist/queries/index.d.ts",
      "default": "./src/queries/index.ts"
    },
    "./fetchers": {
      "types": "./dist/fetchers/index.d.ts",
      "default": "./src/fetchers/index.ts"
    },
    "./tanstack-query": {
      "types": "./dist/tanstack-query.d.ts",
      "default": "./src/tanstack-query.ts"
    },
    "./axios": {
      "types": "./dist/axios.d.ts",
      "default": "./src/axios.ts"
    },
    "./globalErrorHandler": {
      "types": "./dist/globalErrorHandler.d.ts",
      "default": "./src/globalErrorHandler.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,md}\"",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.1.16",
    "eslint": "^9.34.0",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@repo/util": "workspace:*",
    "@tanstack/react-query": "^5.62.8",
    "axios": "^1.7.9",
    "qs": "^6.15.1"
  },
  "peerDependencies": {
    "react": "^19.0.1"
  },
  "prettier": "@repo/prettier-config"
}
